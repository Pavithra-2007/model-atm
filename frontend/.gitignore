# =========================
# MERN Stack Common .gitignore
# =========================

# =========================
# Dependencies
# =========================
backend/node_modules/
frontend/node_modules/

# =========================
# Environment Variables
# =========================
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*

!.env.example

# =========================
# Logs
# =========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# Build folders
# =========================
frontend/dist/
frontend/build/
frontend/.next/
frontend/out/

# =========================
# Cache
# =========================
.cache/
.parcel-cache/
.eslintcache

# =========================
# Coverage
# =========================
coverage/

# =========================
# Uploads
# =========================
backend/uploads/

# =========================
# Runtime files
# =========================
pids/
*.pid
*.seed
*.pid.lock

# =========================
# TypeScript
# =========================
*.tsbuildinfo

# =========================
# IDE / Editor
# =========================
.vscode/
.idea/

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db

# =========================
# Temporary files
# =========================
tmp/
temp/
*.tmp